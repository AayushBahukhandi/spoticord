# Copy to .env and fill in real values. Used by docker-compose and the app services.
# Do not commit .env (it should be in .gitignore).

# --- Required: Discord & Spotify (from Discord Developer Portal & Spotify Dashboard) ---
DISCORD_TOKEN=your_discord_bot_token
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# --- Optional: Discord dev (slash commands in one server only) ---
# GUILD_ID=your_discord_guild_id

# --- Optional: PostgreSQL (defaults used by docker-compose if unset) ---
# POSTGRES_USER=spoticord
# POSTGRES_PASSWORD=spoticord
# POSTGRES_DB=spoticord

# --- Required for production: public URL of Spoticord Link ---
# When hosting: set these to the URL users will use (e.g. https://link.yourdomain.com).
# Add the exact redirect URI in Spotify Developer Dashboard (e.g. https://link.yourdomain.com/authorize).
# LINK_URL=https://link.yourdomain.com/
# SPOTIFY_REDIRECT_URI=https://link.yourdomain.com/authorize

# --- Optional: port for Link app (default 3000) ---
# LINK_PORT=3000
